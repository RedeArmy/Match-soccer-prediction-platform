# ══════════════════════════════════════════════════════════════════════════════
# World Cup Quiniela — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values for your local environment:
#
#   cp .env.example .env
#
# NEVER commit .env to version control. It is listed in .gitignore.
# In production, inject these variables via your secrets manager
# (AWS Secrets Manager, HashiCorp Vault, GCP Secret Manager, etc.).
#
# Variable naming convention: WCQ_<SECTION>_<KEY>
# Nested config keys use a flat underscore separator, e.g.:
#   config key  "server.readTimeout"  →  env var  WCQ_SERVER_READTIMEOUT
#
# ══════════════════════════════════════════════════════════════════════════════

# ── HTTP Server ───────────────────────────────────────────────────────────────
WCQ_SERVER_PORT=8080

# Timeout for reading the full request, including body.
# Increase for endpoints that accept large file uploads.
WCQ_SERVER_READTIMEOUT=10s

# Timeout for writing the complete response.
# Must be longer than the slowest handler (e.g. a full ranking recalculation).
WCQ_SERVER_WRITETIMEOUT=30s

# Timeout for idle keep-alive connections.
# Should align with your load balancer's idle timeout setting.
WCQ_SERVER_IDLETIMEOUT=60s

# ── PostgreSQL Docker container ───────────────────────────────────────────────
# These variables are read by docker-compose.yml to configure the local
# Postgres container. Change them if you are sharing a Postgres instance
# across multiple projects on the same machine to avoid name collisions.
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# Format: postgres://user:password@host:port/dbname?sslmode=disable
# For production, use sslmode=require and provide a CA certificate.
# Must match the POSTGRES_* values above for local development.
WCQ_DATABASE_DSN=postgres://<user>:<password>@localhost:5432/<dbname>?sslmode=disable

# Maximum number of open connections to the database server.
# Set this below the database server's max_connections limit.
# A typical starting point is: (number_of_api_pods × 25) < max_connections.
WCQ_DATABASE_MAXOPENCONNS=25

# Minimum number of connections kept open between traffic bursts.
# Prevents cold-start latency when the pool has drained completely.
WCQ_DATABASE_MAXIDLECONNS=5

# Maximum age of a connection before it is closed and replaced.
# Helps distribute connections evenly across database replicas
# and prevents accumulation of long-lived connections on the server.
WCQ_DATABASE_CONNMAXLIFETIME=5m

# ── Redis ─────────────────────────────────────────────────────────────────────
WCQ_REDIS_ADDR=localhost:6379

# Leave empty if your Redis instance does not require authentication.
WCQ_REDIS_PASSWORD=

# Redis logical database index (0–15). Use 0 unless you are sharing
# a Redis instance across multiple applications.
WCQ_REDIS_DB=0

# ── Logger ────────────────────────────────────────────────────────────────────
# Level: debug | info | warn | error
# Use "debug" locally to see all internal operations.
# Use "info" or "warn" in production to reduce log volume.
WCQ_LOGGER_LEVEL=info

# Encoding: json | console
# Use "console" locally for human-readable, coloured output.
# Use "json" in production so that log aggregation tools can parse fields.
WCQ_LOGGER_ENCODING=console

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to make cross-origin requests.
# In production, set this to your exact frontend domain (e.g. https://myapp.com).
# Never use a wildcard in production with credentialed requests.
WCQ_CORS_ALLOWEDORIGINS=http://localhost:3000

# ── Clerk Authentication ──────────────────────────────────────────────────────
# JWKS endpoint published by Clerk. Found in the Clerk dashboard under
# API Keys → Advanced → JWKS URL.
# Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
WCQ_CLERK_JWKSURL=

# ── JWT Authentication ────────────────────────────────────────────────────────
# REQUIRED. The server will refuse to start if this is empty.
# Generate a secure value with: openssl rand -base64 32
WCQ_JWT_SECRET=

# Duration for which issued tokens remain valid.
# Shorter expiration improves security but increases the frequency of
# re-authentication. 24h is a reasonable default for a quiniela application.
WCQ_JWT_EXPIRATION=24h
