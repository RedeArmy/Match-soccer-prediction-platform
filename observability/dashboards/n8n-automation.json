{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "n8n automation trigger monitoring: DLQ overflow events, circuit breaker trips, and payment error escalations that drive n8n workflow executions.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Trigger Summary",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Current DLQ depth. A non-zero value triggers the dlq-overflow-alert n8n workflow.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 10 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "outbox_dlq_depth",
          "legendFormat": "DLQ depth",
          "refId": "A"
        }
      ],
      "title": "DLQ Depth (dlq-overflow trigger)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of circuit breakers currently open or half-open. Each trip triggers the circuit-breaker-alert n8n workflow.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(circuit_breaker_state > 0) or vector(0)",
          "legendFormat": "Open breakers",
          "refId": "A"
        }
      ],
      "title": "Open Circuit Breakers (cb-alert trigger)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Payment error rate in the last 5 minutes. Errors trigger the payment-error-escalation n8n workflow.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.001 },
            { "color": "red", "value": 0.01 }
          ]},
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(payment_processing_duration_seconds_count{status!=\"success\"}[5m]))",
          "legendFormat": "Payment errors/s",
          "refId": "A"
        }
      ],
      "title": "Payment Errors (payment-escalation trigger)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Oldest pending outbox entry age. When this exceeds notify.outbox_stale_lock_threshold_sec it triggers the DLQ monitor and indirectly n8n notifications.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 600 }
          ]},
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "outbox_oldest_pending_age_seconds",
          "legendFormat": "Stale lag (s)",
          "refId": "A"
        }
      ],
      "title": "Outbox Stale Lag",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "DLQ Overflow — dlq-overflow-alert workflow",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "DLQ depth over time. Each transition from 0 to N>0 fires a POST to n8n /webhook/dlq-overflow and logs an ERROR via the DLQ monitor worker.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "lineWidth": 2, "fillOpacity": 30 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 10 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 7,
      "options": { "legend": { "calcs": ["max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "outbox_dlq_depth",
          "legendFormat": "DLQ depth",
          "refId": "A"
        }
      ],
      "title": "DLQ Depth over Time",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 8,
      "title": "Circuit Breaker Trips — circuit-breaker-alert workflow",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Circuit breaker state per backend over time. Each transition to state=1 (open) fires a POST to n8n /webhook/circuit-breaker-open via the StateChangeHook registered at server startup.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "mappings": [],
          "max": 2,
          "min": 0,
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 9,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "circuit_breaker_state",
          "legendFormat": "{{ backend }}",
          "refId": "A"
        }
      ],
      "title": "Circuit Breaker State by Backend (0=closed, 1=open, 2=half-open)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 10,
      "title": "Payment Errors — payment-error-escalation workflow",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Payment error rate by provider over time. Each non-success webhook event fires a POST to n8n /webhook/payment-error — the payment-error-escalation workflow then routes to Slack or email.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 20 }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max", "sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (provider) (rate(payment_processing_duration_seconds_count{status!=\"success\"}[$__rate_interval]))",
          "legendFormat": "{{ provider }} errors/s",
          "refId": "A"
        }
      ],
      "title": "Payment Error Rate by Provider",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Payment success rate by provider. A drop below SLO threshold (99%) is the leading indicator for payment-error-escalation workflow triggers.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "percent", "min": 0, "max": 100 }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "min"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "asc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum by (provider) (rate(payment_processing_duration_seconds_count{status=\"success\"}[$__rate_interval])) / sum by (provider) (rate(payment_processing_duration_seconds_count[$__rate_interval]))",
          "legendFormat": "{{ provider }} success %",
          "refId": "A"
        }
      ],
      "title": "Payment Success Rate by Provider",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 13,
      "title": "Bank Transfer & Payout Notifications",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Outbox event dispatch rate for notification events related to bank transfers and payouts. These events drive the bank-transfer-admin-notify and payout-confirmation n8n workflows via the AdminDispatcher.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10 }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "id": 14,
      "options": { "legend": { "calcs": ["mean", "sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (event_type, status) (rate(dispatcher_events_total{event_type=~\"bank_transfer.*|payout.*|withdrawal.*\"}[$__rate_interval]))",
          "legendFormat": "{{ event_type }} / {{ status }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (status) (rate(email_deliveries_total[$__rate_interval]))",
          "legendFormat": "email / {{ status }}",
          "refId": "B"
        }
      ],
      "title": "Financial Notification Dispatch (bank-transfer & payout workflows)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Phase 9 will add /api/admin/observability/n8n/executions/recent for live workflow execution tracking. Until then, use this dashboard to monitor trigger conditions that drive n8n workflows.",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 41 },
      "id": 15,
      "options": { "content": "## Phase 9 — Live n8n Execution Metrics\n\nOnce Phase 9 admin endpoints are deployed (`GET /api/admin/observability/n8n/executions/recent`), this dashboard can be extended with a JSON datasource panel showing:\n- Workflow execution rate and failure count\n- Last execution timestamps per workflow\n- Workflow-level error rates\n\nUntil then, the panels above surface the **trigger conditions** (DLQ depth, circuit breaker state, payment errors) that drive n8n workflow executions.", "mode": "markdown" },
      "pluginVersion": "11.1.0",
      "title": "Note: Phase 9 Execution Metrics",
      "type": "text"
    }

  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["wcq", "observability", "n8n", "automation"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "WCQ — n8n Automation",
  "uid": "wcq-n8n-automation",
  "version": 1
}
